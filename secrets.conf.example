# bastion secrets.conf — ANNOTATED EXAMPLE. Copy to the path named by machine.conf
# [machine] secrets_file (default /etc/bastion/secrets.conf), chmod 600, and fill in.
#
# HARD RULES:
#   * secrets.conf is NEVER committed to git (it is in .gitignore).
#   * secrets.conf is NEVER backed up to NFS/cloud and NEVER referenced in logs.
#   * machine.conf holds only the PATH to this file — never a key value.
#   * The API key reaches the analyzer via a systemd EnvironmentFile, not via templates.

[secrets]
# Paste your Anthropic API key here (it begins with the usual Anthropic key prefix).
anthropic_api_key = REPLACE_WITH_YOUR_API_KEY

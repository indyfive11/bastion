# bastion machine.conf — ANNOTATED EXAMPLE. Copy to /etc/bastion/machine.conf (system
# install) or ~/.config/bastion/machine.conf (user install) and edit. All values here are
# generic placeholders (RFC1918 / documentation values) — NEVER commit a real machine.conf.
#
# `bastion generate` resolves the templates/ files against this file ({{ section.key }}
# notation) and also renders the shell-sourced /etc/bastion/machine.env that the operational
# scripts (edge-watchdog, lan-verify, net-confirm, net-rollback, edge-dnsblock-update) read.
#
# Comments are on their own lines (a value may itself contain '#', e.g. dns_upstream).

[machine]
# mode: edge | endpoint
mode = edge
# profile: full-edge | basic-edge | full-endpoint | minimal-endpoint | custom
profile = full-edge
# active layers (derived from profile unless custom)
layers = l0,l1,l2,l3,l4,l5,l6
# distro: arch | debian | ubuntu | fedora | auto
distro = arch
secrets_file = /etc/bastion/secrets.conf
# firewall_scope: ownership mode. exclusive = bastion owns the whole nft ruleset (flush ruleset);
# cooperative = manage only bastion's own table, leaving co-resident firewalls (libvirt/docker) intact.
firewall_scope = exclusive
# schema_version: machine.conf format version — `bastion migrate` carries an old conf forward.
schema_version = 2

[interfaces]
# LAN interface — detected by wizard, confirm or override
lan = eth0
# WAN interface (edge mode only)
wan = eth1
# ZeroTier interface — auto-detected, or unused
zt_iface = zt0
# upstream relay/tunnel interface (L5, optional)
wg_vps_iface = wg_vps
# WireGuard server interface (L5, optional)
wg_server_iface = wg0

[network]
# LAN subnet (edge mode)
lan_cidr = 10.0.1.0/24
# this node's LAN IP
lan_ip = 10.0.1.1
# upstream default gateway (router) — ISP-up probe + default-route restore
gateway = 10.0.1.254
# IPv6 forwarding (edge mode): yes = the box routes IPv6 too, so the v6 firewall rules it ships
# are live (a real edge router); no = v4-only routing, the v6 rules stay ready-but-inert. When
# yes, generate also pins accept_ra=2 on the WAN so enabling forwarding can't strip the box's own
# WAN IPv6. Ignored in endpoint mode (endpoints never forward).
ipv6_forward = yes
# ZeroTier subnet (edge full profile); set equal to lan_cidr if unused
zt_cidr = 10.147.17.0/24
# WireGuard server subnet (L5)
wg_server_cidr = 10.8.0.0/24
# always-accept management IPs (comma-separated, user-entered)
trusted_hosts = 10.0.1.50, 10.0.1.55
# inbound service ports to OPEN to LAN/overlay (any source). For a box that runs bastion AND serves
# apps (media/*arr/ZeroTier/etc.) the default-drop ruleset would block them — list them here. Tokens
# are `port` or `port/proto` (proto tcp|udp, default tcp), comma/space-separated. Blank = a locked-down
# client endpoint. On edge the WAN stays closed regardless (WAN drop fires first). e.g. 8096, 53/udp
service_ports =
# DNS upstream — see docs/options/dns-options.md (local stub shown)
dns_upstream = 127.0.0.1#5335
# L4 DHCP pool start
dhcp_range_start = 10.0.1.100
# L4 DHCP pool end
dhcp_range_end = 10.0.1.249
# L4 DHCP lease time
dhcp_lease = 12h

[ports]
# SSH listen port — detected from running sshd, confirm or change
ssh = 22

[ai]
# claude backend; mock = edge-ai-backend-mock
backend_cmd = /usr/local/sbin/edge-ai-backend-claude
model = claude-opus-4-8
max_intents = 32
# How often edge-ai runs (the AI run-cadence control knob; rendered into edge-ai.timer's
# OnUnitActiveSec). Any systemd time span: 4h, 30min, 90s, 2h30m, 1d. The wizard prompts for and
# validates this; after editing it, re-render (bastion generate / layer install l3) and re-arm
# (bastion ai enable) to apply. Note: m = minutes, M = months.
timer_interval = 4h
# regular | advanced | expert — controls how much config the AI is SHOWN, not what it can apply.
# In every depth, base/access changes (e.g. SSH port) are proposed to the human-review queue
# (proposals.jsonl) and NEVER auto-applied — see edge-ai-analyze / edge-reconciler. Only the
# ai_* sets are ever applied automatically.
depth = regular
# RESERVED (inert): knobs for a future expert-mode AUTO-APPLY path that does not exist yet. Since
# base changes are always human-reviewed today, nothing reads these — they are placeholders so the
# config shape is stable if/when auto-apply (gated by a canary + confidence floor) is implemented.
expert_canary_seconds = 300
expert_confidence_floor = 0.92

[recovery]
# bastion-recovery (L0, always installed, disabled by default). All optional — at start the
# service detects live sshd port(s) and binds an adaptive union of free ports; these are
# defaults/overrides only (live detection wins when machine.conf is stale).
# extra recovery sshd port; blank = auto-pick a free high port
dedicated_port =
# self-destruct window (seconds) before auto-stop unless `bastion recovery extend`
window_seconds = 1800
# also bind 22 when it is free (universal fallback)
try_port_22 = yes

[monitoring]
# L6 watchdog/verify/alert + L4 DNS-sinkhole knobs, rendered into machine.env.
# egress canary URL (net-confirm, flowcheck)
egress_probe = https://api.anthropic.com
# relay far-end / masquerade-side IP (edge-watchdog, lan-verify); blank if no relay
relay_dst = 10.0.0.3
# PUBLIC endpoint IP of the upstream relay/tunnel — the address the tunnel dials OUT to (e.g. a
# WireGuard `Endpoint` host). Distinct from relay_dst (the tunnel's inner/private IP). The
# reconciler folds this into the never-block allowlist so a poisoned IP feed can never blackhole
# your own uplink's far end. Blank if no upstream relay.
relay_endpoint =
# NetworkManager connection to re-up on rollback; blank if not using NM
nm_conn =
# space-separated IP-blocklist feed URLs (edge-feed-fetch); blank = built-in defaults
feed_sources =
# space-separated host-list URLs; blank = built-in default (StevenBlack)
dnsblock_sources =
# space-separated domains the DNS sinkhole must NEVER block (covers subdomains); on top of the
# shipped never-sink defaults + the auto-protected egress/DNS-upstream hosts
dns_allowlist =

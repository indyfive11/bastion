#!/usr/bin/env bash
# edge-dnsblock-update — DNS sinkhole generator for unbound (L4).
# Fetches curated domain blocklists (ads + trackers + malware), emits unbound
# `local-zone ... always_nxdomain` entries to /etc/unbound/blocklist.conf, VALIDATES with
# unbound-checkconf, and reloads unbound. Reverts on bad config. Runs as root via timer.
# Override the feed list by setting DNSBLOCK_SOURCES (space-separated URLs) in machine.env
# (or manage them with `bastion dnsblock add|remove|list`).
#
# Accepts the three common blocklist shapes, so most public lists drop in unchanged:
#   * hosts        `0.0.0.0 domain` / `127.0.0.1 domain` / `::1 domain`   (StevenBlack, HaGeZi hosts/)
#   * plain domain `domain` (one per line)                                (HaGeZi domains/, AdGuard)
#   * adblock      `||domain^` (plain anchored-domain rules only)         (OISD, EasyList-style)
# Element-hiding / regex / wildcard / option rules can't map to a domain sinkhole and are skipped.
set -u
[ -r /etc/bastion/machine.env ] && . /etc/bastion/machine.env

# need <bin>... — B4 preflight: exit early with a clear message naming any missing required
# command, instead of failing obscurely mid-run. Reports to stderr + journal.
need(){ local b miss=''
  for b in "$@"; do command -v "$b" >/dev/null 2>&1 || miss="$miss $b"; done
  [ -z "$miss" ] && return 0
  printf 'bastion %s: missing required command(s):%s — install them and re-run\n' "${0##*/}" "$miss" >&2
  command -v logger >/dev/null 2>&1 && logger -t bastion "${0##*/}: missing required command(s):$miss"
  exit 1
}
# curl fetches the feeds; unbound-checkconf validates before reload (this is an L4/unbound tool).
need curl unbound-checkconf
OUT=/etc/unbound/blocklist.conf
DEFAULT_SOURCES="https://raw.githubusercontent.com/StevenBlack/hosts/master/hosts"
read -r -a SOURCES <<< "${DNSBLOCK_SOURCES:-$DEFAULT_SOURCES}"

# Normalize any supported list shape to one bare lowercase domain per line. Liberal on purpose —
# the sort/validate pass below is the authority (drops anything that isn't a plausible domain).
extract_domains(){
  awk '
    { gsub(/\r/,""); l=$0 }
    l ~ /^[[:space:]]*$/    { next }                       # blank
    l ~ /^[[:space:]]*[#!]/ { next }                       # comment (# hosts/plain, ! adblock)
    l ~ /^\[/               { next }                       # adblock header e.g. [Adblock Plus 2.0]
    # adblock plain anchored-domain rule: ||domain.tld^ (optionally ^$options); skip wildcards/paths
    l ~ /^\|\|[A-Za-z0-9._-]+\.[A-Za-z0-9._-]+\^/ {
      d=l; sub(/^\|\|/,"",d); sub(/\^.*$/,"",d); print tolower(d); next
    }
    # hosts format: <sink-ip> <domain> [# comment]
    ($1=="0.0.0.0" || $1=="127.0.0.1" || $1=="::1") && $2 ~ /\./ { print tolower($2); next }
    # plain single-token domain
    NF==1 && $1 ~ /^[A-Za-z0-9._-]+\.[A-Za-z0-9._-]+$/ { print tolower($1); next }
  '
}

T=$(mktemp -d); trap 'rm -rf "$T"' EXIT
ok=0; : > "$T/dom"
for u in "${SOURCES[@]}"; do
  if d=$(curl -fsS -m 60 --retry 2 "$u" 2>/dev/null); then
    printf '%s\n' "$d" | extract_domains >> "$T/dom"
    ok=$((ok+1)); logger -t edge-dnsblock "fetched OK: $u"
  else
    logger -t edge-dnsblock "FETCH FAILED: $u"
  fi
done
[ "$ok" -eq 0 ] && { logger -t edge-dnsblock "all sources failed; keeping current blocklist"; exit 1; }
# Final validation pass: a plausible domain, and NOT a bare IP / localhost-ish token.
sort -u "$T/dom" | grep -E '^[a-z0-9_.-]+\.[a-z0-9_.-]+$' \
  | grep -vE '^([0-9.]+|localhost|localhost\.localdomain|local|broadcasthost|ip6-[a-z]+)$' > "$T/clean"
{ echo "# bastion DNS sinkhole (ads+trackers+malware) — generated by edge-dnsblock-update. DO NOT EDIT."
  awk '{printf "local-zone: \"%s.\" always_nxdomain\n",$1}' "$T/clean"; } > "$T/new"
[ -f "$OUT" ] && cp -a "$OUT" "$T/prev"
cp "$T/new" "$OUT"
if unbound-checkconf /etc/unbound/unbound.conf >/dev/null 2>&1; then
  systemctl reload unbound && logger -t edge-dnsblock "loaded $(wc -l < "$T/clean") blocked domains"
else
  [ -f "$T/prev" ] && cp "$T/prev" "$OUT"; systemctl reload unbound 2>/dev/null
  logger -t edge-dnsblock "unbound-checkconf FAILED — reverted blocklist"; exit 1
fi

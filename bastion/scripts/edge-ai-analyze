#!/usr/bin/env python3
# edge-ai-analyze — the UNPRIVILEGED analyzer (runs as user edge-ai; no sudo, no nft).
#
# Reads the sanitized /var/lib/edge-ai/signals.json, invokes the configured pluggable
# BACKEND_CMD (signals on stdin -> intent-envelope JSON on stdout), validates the result
# against intent.schema.json, stamps each intent with an ABSOLUTE `expires` epoch, and
# atomically writes /var/lib/edge-ai/intents.json. The reconciler (root) re-validates and
# applies. This process can NEVER touch the firewall.
#
# Self-heal: absolute expiry means a DEAD analyzer's blocks count down and drop out even
# though intents.json persists (the reconciler applies timeout = expires - now). On ANY
# error we leave the previous intents.json UNTOUCHED so its entries keep expiring normally.
#
import json, os, re, shlex, subprocess, sys, time

_CTRL_RE = re.compile(r"[\x00-\x1f\x7f]")   # C0 controls + DEL (ANSI ESC \x1b, CR/LF, tab, ...)
def _clean(s, n):
    """Strip control chars from model-origin free text and length-cap it (D6). The reason/description
    a backend returns reach the operator's terminal (edge-ctl) and the journal verbatim; a crafted
    ANSI/escape sequence there could spoof output or inject log lines. One-liners only — newlines/tabs
    go too."""
    return _CTRL_RE.sub("", str(s))[:n]

BACKENDCONF = "/etc/edge-ai/backend.conf"
SCHEMA      = "/etc/edge-ai/intent.schema.json"
SIGNALS     = "/var/lib/edge-ai/signals.json"
INTENTS     = "/var/lib/edge-ai/intents.json"
PROPOSALS   = "/var/lib/edge-ai/proposals.jsonl"   # human-review queue (propose_base_change)
APPLY_ACTIONS = {"block_src", "ratelimit_src", "tarpit_src"}

def log(m): sys.stderr.write(f"edge-ai-analyze: {m}\n")
def die(m, code=1):
    log(m); log("leaving previous intents.json untouched (self-heal via TTL)"); sys.exit(code)

def load_conf():
    cfg = {"BACKEND_CMD": "/usr/local/sbin/edge-ai-backend-mock", "MODEL": "claude-opus-4-8",
           "MAX_INTENTS": 32, "MAX_TTL": 86400, "MIN_TTL": 60, "BACKEND_TIMEOUT": 60}
    try:
        with open(BACKENDCONF) as f:
            for line in f:
                line = line.split("#", 1)[0].strip()
                if not line or "=" not in line: continue
                k, v = line.split("=", 1)
                cfg[k.strip()] = v.strip()
    except FileNotFoundError:
        log(f"WARNING: {BACKENDCONF} missing, using defaults")
    for k in ("MAX_INTENTS", "MAX_TTL", "MIN_TTL", "BACKEND_TIMEOUT"):
        try: cfg[k] = int(cfg[k])
        except (ValueError, TypeError): pass
    return cfg

def main():
    cfg = load_conf()
    try:
        with open(SIGNALS) as f:
            signals_raw = f.read()
        json.loads(signals_raw)   # sanity parse
    except Exception as e:
        die(f"cannot read/parse {SIGNALS}: {e}")

    # ---- invoke the pluggable backend (the provider-agnostic process contract) ----
    # shlex.split so a BACKEND_CMD with quoted/spaced arguments parses correctly
    # (e.g. `/usr/bin/python3 /opt/my backend.py --flag`), not naive whitespace split.
    cmd = shlex.split(cfg["BACKEND_CMD"])
    # D5: hand the backend a MINIMAL environment — a safe baseline + the model + ONLY the declared
    # secret var (KEY_ENV in backend.conf, default ANTHROPIC_API_KEY). The old `dict(os.environ)`
    # forwarded the API key AND every other inherited variable to the BACKEND_CMD, including to a
    # local/keyless backend with no business seeing the cloud key. (A keyless backend simply has no
    # key in our environ to forward, so the default is safe.)
    base_keep = ("PATH", "HOME", "LANG", "LC_ALL", "LC_CTYPE", "TMPDIR")
    env = {k: os.environ[k] for k in base_keep if k in os.environ}
    env.setdefault("PATH", "/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin")
    env["EDGE_AI_MODEL"] = str(cfg["MODEL"])
    key_env = str(cfg.get("KEY_ENV", "ANTHROPIC_API_KEY")).strip()
    if key_env and key_env in os.environ:
        env[key_env] = os.environ[key_env]
    try:
        p = subprocess.run(cmd, input=signals_raw, capture_output=True, text=True,
                           timeout=cfg["BACKEND_TIMEOUT"], env=env)
    except subprocess.TimeoutExpired:
        die(f"backend {cmd[0]} timed out after {cfg['BACKEND_TIMEOUT']}s")
    except Exception as e:
        die(f"backend {cmd[0]} exec failed: {e}")
    if p.returncode != 0:
        die(f"backend {cmd[0]} rc={p.returncode}: {p.stderr.strip()[:300]}")
    try:
        env_doc = json.loads(p.stdout)
    except json.JSONDecodeError as e:
        die(f"backend output not JSON: {e}; head={p.stdout[:200]!r}")

    # ---- validate envelope shape (jsonschema if available, else manual) ----
    try:
        import jsonschema
        with open(SCHEMA) as f:
            schema = json.load(f)
        jsonschema.validate(env_doc, schema)
    except ImportError:
        if not (isinstance(env_doc, dict) and env_doc.get("version") == 1
                and isinstance(env_doc.get("intents"), list)):
            die("envelope failed manual validation (no jsonschema lib)")
    except Exception as e:
        die(f"envelope failed schema validation: {e}")

    now = int(time.time())
    backend_id = _clean(env_doc.get("backend", cmd[0]), 200)
    applied, proposals = [], []
    for it in env_doc.get("intents", []):
        action = it.get("action")
        if action == "propose_base_change":
            proposals.append({"ts": now, "backend": backend_id,
                              "description": _clean(it.get("description", ""), 600),
                              "reason": _clean(it.get("reason", ""), 280)})
            continue
        if action not in APPLY_ACTIONS:
            log(f"drop unknown action {action!r}"); continue
        cidr = str(it.get("cidr", "")).strip()
        if not cidr:
            log(f"drop {action}: missing cidr"); continue
        ttl = it.get("ttl", cfg["MIN_TTL"])
        try: ttl = int(ttl)
        except (ValueError, TypeError): ttl = cfg["MIN_TTL"]
        ttl = max(cfg["MIN_TTL"], min(cfg["MAX_TTL"], ttl))   # clamp
        applied.append({
            "action": action, "cidr": cidr, "ttl": ttl, "expires": now + ttl,
            "reason": _clean(it.get("reason", ""), 280),
            "confidence": it.get("confidence"),
        })
        if len(applied) >= cfg["MAX_INTENTS"]:
            log(f"hit MAX_INTENTS={cfg['MAX_INTENTS']}, truncating"); break

    out = {"version": 1, "generated_epoch": now, "backend": backend_id, "intents": applied}
    os.makedirs(os.path.dirname(INTENTS), exist_ok=True)
    tmp = INTENTS + ".tmp"
    with open(tmp, "w") as f:
        json.dump(out, f, separators=(",", ":"))
    os.replace(tmp, INTENTS)

    if proposals:
        with open(PROPOSALS, "a") as f:
            for pr in proposals:
                f.write(json.dumps(pr, separators=(",", ":")) + "\n")

    log(f"backend={backend_id} -> {len(applied)} apply-intents, {len(proposals)} proposals")
    print(json.dumps({"backend": backend_id, "apply_intents": len(applied),
                      "proposals": len(proposals)}))
    return 0

if __name__ == "__main__":
    sys.exit(main())

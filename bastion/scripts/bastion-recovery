#!/usr/bin/env bash
# bastion-recovery — emergency, console-initiated SSH recovery (L0, always installed,
# disabled by default). Machine-agnostic and SELF-CONFIGURING: it detects the real sshd
# port(s) at START time (never assumes 22), binds an adaptive union of FREE ports, opens an
# independent nft override table for exactly those ports, stands up a second sshd instance
# with a one-time password on an EPHEMERAL recovery user, and ANNOUNCES on the console exactly
# how to connect. Active only while running; leaves the main firewall + main sshd untouched.
#
# Subcommands:  start (default) | stop | extend | status
# Honors machine.env (optional): RECOVERY_DEDICATED_PORT, RECOVERY_WINDOW_SECONDS,
# RECOVERY_TRY_PORT_22. Live detection wins when those are stale.
set -u

[ -r /etc/bastion/machine.env ] && . /etc/bastion/machine.env
DEDICATED_PORT="${RECOVERY_DEDICATED_PORT:-}"
WINDOW_SECONDS="${RECOVERY_WINDOW_SECONDS:-1800}"
TRY_PORT_22="${RECOVERY_TRY_PORT_22:-yes}"

RUN=/run/bastion-recovery
LOCKFILE="${RUN}.lock"             # start-serialization lock (C2); sibling file, not the run dir
RECOVERY_USER=bastion-rescue
DESTRUCT_UNIT=bastion-recovery-destruct
# Main managed nft table (edge: "inet edge", endpoint: "inet bastion") — from machine.env's
# NFT_TABLE, else detected live at use time. The C1 reachability punch (ensure_main_accept) needs it.
MAIN_TABLE="${NFT_TABLE:-}"
RECOVERY_RULE_TAG="bastion-recovery"
log(){ logger -t bastion-recovery "$*" 2>/dev/null; printf 'bastion-recovery: %s\n' "$*" >&2; }
# console-only output — NEVER via logger, so the one-time password never persists in the system
# journal (C3). Writes to stderr, which the console/IPMI recovery session sees.
announce(){ printf 'bastion-recovery: %s\n' "$*" >&2; }

# need <bin>... — B4 preflight: exit early with a clear message naming any missing required
# command, instead of failing obscurely mid-run. Reports via log() (journal + stderr).
need(){ local b miss=''
  for b in "$@"; do command -v "$b" >/dev/null 2>&1 || miss="$miss $b"; done
  [ -z "$miss" ] && return 0
  log "missing required command(s):$miss — install them and re-run"
  exit 1
}

# ---- detection helpers ----------------------------------------------------
detect_ssh_ports() {
  local ports
  ports=$(sshd -T 2>/dev/null | awk '/^port /{print $2}')
  [ -z "$ports" ] && ports=$(awk 'tolower($1)=="port" && $2 ~ /^[0-9]+$/ {print $2}' /etc/ssh/sshd_config 2>/dev/null)
  [ -z "$ports" ] && ports=$(ss -tlnH 2>/dev/null | awk '/"sshd"/{n=split($4,a,":"); print a[n]}' | sort -un)
  [ -z "$ports" ] && ports=22
  printf '%s\n' $ports | sort -un
}
port_free() { ! ss -tlnH 2>/dev/null | awk '{print $4}' | grep -qE "[:.]$1\$"; }
pick_free_port() { local p; for p in 2222 2022 22222 64022 50022; do port_free "$p" && { echo "$p"; return; }; done; echo 0; }

# ---- main-table reachability punch (C1) -----------------------------------
# The independent `inet bastion_recovery` table accepts the recovery ports, but in nftables an
# `accept` in one base chain is NOT terminal: the main table's input chain (policy drop, evaluated
# at a later priority) still drops a NEW connection to a recovery-only port. So on a default-drop
# edge the override table alone does NOT guarantee reachability. We therefore ALSO insert an accept
# for the bound ports at the TOP of the main table's input chain, tagged for clean removal on stop.
# heal_light reloads /etc/nftables.conf (dropping this rule) so edge-watchdog re-invokes
# `bastion-recovery reassert` after a reload while a window is open. No main table (recovery run
# before/without L0) => the override table is the only surface and this is a no-op.
resolve_main_table() {
  local t
  if [ -n "$MAIN_TABLE" ]; then printf '%s' "$MAIN_TABLE"; return; fi
  for t in "inet edge" "inet bastion"; do
    nft list table $t >/dev/null 2>&1 && { printf '%s' "$t"; return; }
  done
  printf ''
}
remove_main_accept() {
  local t h; t=$(resolve_main_table); [ -n "$t" ] || return 0
  while h=$(nft -a list chain $t input 2>/dev/null | awk -v tag="$RECOVERY_RULE_TAG" '$0 ~ tag {print $NF; exit}'); [ -n "$h" ]; do
    nft delete rule $t input handle "$h" 2>/dev/null || break
  done
}
ensure_main_accept() {   # $1 = comma-separated portset
  local t; t=$(resolve_main_table); [ -n "$t" ] || return 0
  nft list chain $t input >/dev/null 2>&1 || return 0
  remove_main_accept     # idempotent: clear any prior recovery rule first
  nft insert rule $t input tcp dport { $1 } accept comment \"$RECOVERY_RULE_TAG\" 2>/dev/null \
    || log "WARN: could not punch recovery accept into '$t input' (override table only)"
}

arm_destruct() {
  systemctl stop "${DESTRUCT_UNIT}.timer" 2>/dev/null || true
  systemd-run --quiet --unit="$DESTRUCT_UNIT" --on-active="${WINDOW_SECONDS}s" \
    /usr/bin/systemctl stop bastion-recovery 2>/dev/null \
    || log "WARN: could not arm self-destruct timer (manual stop required)"
}

# ---- start ----------------------------------------------------------------
do_start() {
  [ "$(id -u)" -eq 0 ] || { log "must run as root"; exit 1; }
  # Preflight the tools the recovery surface is built from, BEFORE we create any of it — a missing
  # one mid-flow would leave a half-built privileged surface for the cleanup trap to tear down.
  need sshd useradd chpasswd nft ss flock
  # C2: serialize starts + refuse to start over a LIVE session. Without this, a 2nd `start` races
  # the 1st: it sees the in-use ports, its sshd bind hits EADDRINUSE, and its failure path calls
  # do_stop — dismantling the FIRST session's live recovery. flock makes concurrent starts mutually
  # exclusive; the active-window guard refuses (rather than tears down) an already-running session.
  exec 9>"$LOCKFILE" || { log "FATAL: cannot open start lock $LOCKFILE"; exit 1; }
  flock -n 9 || { log "another bastion-recovery start is in progress — refusing"; exit 1; }
  if [ -f "$RUN/ports" ]; then
    log "recovery is ALREADY ACTIVE on port(s) $(cat "$RUN/ports") — use 'extend' or 'stop' first (refusing to start over it)"
    exit 1
  fi
  mkdir -p "$RUN"; chmod 700 "$RUN"

  # CLEANUP TRAP: from here on we create a privileged surface (OTP user + NOPASSWD-ALL sudoers +
  # recovery sshd). If do_start is interrupted before the self-destruct is armed — SIGTERM from
  # the unit's TimeoutStartSec, an admin Ctrl-C, or an OOM kill — that surface would otherwise
  # persist with NO timer to ever remove it. Tear it all down on any such signal. Cleared only
  # after arm_destruct succeeds (the self-destruct timer then owns teardown).
  trap 'log "interrupted during start — tearing down partial recovery surface"; do_stop quiet; exit 1' INT TERM

  # Build the adaptive bind set from the FREE subset of: main port(s), 22, dedicated.
  local bind="" p
  for p in $(detect_ssh_ports); do port_free "$p" && bind="$bind $p"; done   # (a) operator's known port if main sshd is down
  [ "$TRY_PORT_22" = yes ] && port_free 22 && bind="$bind 22"                 # (b) universal fallback
  if [ -n "$DEDICATED_PORT" ]; then                                          # (c) dedicated
    port_free "$DEDICATED_PORT" && bind="$bind $DEDICATED_PORT"
  else
    local dp; dp=$(pick_free_port); [ "$dp" != 0 ] && bind="$bind $dp"
  fi
  bind=$(printf '%s\n' $bind | sort -un | tr '\n' ' ')
  [ -n "${bind// /}" ] || { log "FATAL: no free port available to bind recovery sshd"; exit 1; }
  printf '%s' "$bind" > "$RUN/ports"

  # Ephemeral recovery user with a one-time password + transient NOPASSWD sudo (for setup).
  local otp; otp=$(tr -dc 'A-Za-z0-9' </dev/urandom | head -c 20)
  if ! id "$RECOVERY_USER" >/dev/null 2>&1; then
    useradd -m -s /bin/bash -c "bastion recovery (ephemeral)" "$RECOVERY_USER" 2>/dev/null \
      || { log "FATAL: could not create recovery user"; exit 1; }
  fi
  printf '%s:%s\n' "$RECOVERY_USER" "$otp" | chpasswd
  # Defense-in-depth backstop (0.1): the self-destruct timer + the boot reaper are the primary
  # teardown paths, but if BOTH somehow fail to run, a date-based account expiry still caps how
  # long an orphaned rescue account can be used. The window is seconds (chage granularity is days),
  # so expire at tomorrow — coarse, but it guarantees the account can't be logged into indefinitely.
  # do_stop/destruct removes the user outright; this only matters if neither ever runs.
  chage -E "$(date -d 'tomorrow' +%Y-%m-%d 2>/dev/null || date +%Y-%m-%d)" "$RECOVERY_USER" 2>/dev/null || true
  printf '%s ALL=(ALL) NOPASSWD: ALL\n' "$RECOVERY_USER" > /etc/sudoers.d/bastion-recovery
  chmod 440 /etc/sudoers.d/bastion-recovery

  # Ephemeral sshd config — reuse the system host keys (no host-key-changed warning).
  local cfg="$RUN/sshd_config" k
  {
    echo "# bastion-recovery ephemeral sshd — generated at start, removed on stop"
    for p in $bind; do echo "Port $p"; done
    echo "PasswordAuthentication yes"
    echo "KbdInteractiveAuthentication yes"
    echo "UsePAM yes"
    echo "PermitRootLogin no"
    echo "AllowUsers $RECOVERY_USER"
    echo "PidFile $RUN/sshd.pid"
    for k in /etc/ssh/ssh_host_*_key; do [ -f "$k" ] && echo "HostKey $k"; done
  } > "$cfg"

  # nft override: independent table, accepts ONLY the bound ports + ICMP. Does not touch main.
  local portset; portset=$(printf '%s' "$bind" | tr ' ' ',' | sed 's/^,//; s/,$//')
  nft -f - <<NFT 2>/dev/null || log "WARN: nft override load failed (main ruleset may already permit these)"
table inet bastion_recovery {
  chain input {
    type filter hook input priority -50; policy accept;
    tcp dport { $portset } accept
    ip protocol icmp accept
    ip6 nexthdr ipv6-icmp accept
  }
}
NFT

  # C1: also punch the accept into the MAIN managed table so recovery actually wins on a
  # default-drop edge (the override table's accept above is not terminal against the main drop).
  ensure_main_accept "$portset"

  # Start the recovery sshd instance.
  local sshd; sshd=$(command -v sshd)
  "$sshd" -f "$cfg" || { log "FATAL: recovery sshd failed to start"; do_stop quiet; exit 1; }

  arm_destruct
  trap - INT TERM   # recovery surface is up and the self-destruct is armed — hand off teardown to it

  # Announce — the console is the source of truth.
  local ips; ips=$(ip -4 -o addr show scope global 2>/dev/null | awk '{print $4}' | cut -d/ -f1 | tr '\n' ' ')
  # Journal gets a non-secret breadcrumb; the OTP + connect details go to the CONSOLE ONLY (C3).
  log "recovery ACTIVE: bound port(s) $bind, ${WINDOW_SECONDS}s window (login details shown on console only)"
  announce "================ RECOVERY ACTIVE ================"
  announce "  bound port(s) : $bind"
  announce "  reachable IP(s): ${ips:-<none detected — check console/IPMI link>}"
  announce "  login user     : $RECOVERY_USER (sudo enabled)"
  announce "  one-time pass  : $otp"
  announce "  connect, e.g.  : ssh -p ${bind%% *} ${RECOVERY_USER}@${ips%% *}"
  announce "  auto-stop in   : ${WINDOW_SECONDS}s  (extend: bastion recovery extend | stop: systemctl stop bastion-recovery)"
  announce "================================================"
}

# ---- stop -----------------------------------------------------------------
do_stop() {
  systemctl stop "${DESTRUCT_UNIT}.timer" 2>/dev/null || true
  [ -f "$RUN/sshd.pid" ] && kill "$(cat "$RUN/sshd.pid")" 2>/dev/null || true
  pkill -f "sshd -f $RUN/sshd_config" 2>/dev/null || true
  nft delete table inet bastion_recovery 2>/dev/null || true
  remove_main_accept                                  # C1: drop the main-table reachability punch
  rm -f /etc/sudoers.d/bastion-recovery
  if id "$RECOVERY_USER" >/dev/null 2>&1; then userdel -r "$RECOVERY_USER" 2>/dev/null || userdel "$RECOVERY_USER" 2>/dev/null || true; fi
  rm -rf "$RUN"
  [ "${1:-}" = quiet ] || log "recovery stopped: override table removed, recovery sshd down, OTP user revoked. Main firewall unaffected."
}

# ---- reap (boot-time orphan cleanup) --------------------------------------
# Run once at boot by bastion-recovery-reap.service. $RUN lives on tmpfs and is GONE after any
# reboot, but the privileged surface recovery creates — the bastion-rescue user and
# /etc/sudoers.d/bastion-recovery (NOPASSWD: ALL) — persists on disk. So "$RUN absent but that
# on-disk surface present" means recovery did NOT stop cleanly: a crash/power-loss mid-window left
# an orphaned root backdoor. Tear it down. A clean boot (recovery was never active, or it stopped
# normally) leaves nothing matching, so this is a safe no-op.
do_reap() {
  [ "$(id -u)" -eq 0 ] || { log "reap: must run as root"; exit 1; }
  if [ ! -d "$RUN" ] && { [ -f /etc/sudoers.d/bastion-recovery ] || id "$RECOVERY_USER" >/dev/null 2>&1; }; then
    log "boot reaper: orphaned recovery surface found (no $RUN after reboot) — tearing it down"
    do_stop quiet
    log "boot reaper: orphaned recovery surface removed (sudoers drop-in + ephemeral user revoked)"
  fi
}

# ---- reassert (re-punch the main-table accept after a ruleset reload) ------
# edge-watchdog's heal_light reloads /etc/nftables.conf, which recreates the main table fresh and
# so drops the C1 reachability rule. When a recovery window is open, the watchdog calls this right
# after a reload to re-insert the accept (the override table is folded back by heal_light itself).
do_reassert() {
  [ "$(id -u)" -eq 0 ] || exit 0
  [ -f "$RUN/ports" ] || exit 0           # no active window — nothing to reassert
  local bind portset
  bind=$(cat "$RUN/ports")
  portset=$(printf '%s' "$bind" | tr ' ' ',' | sed 's/^,//; s/,$//')
  ensure_main_accept "$portset"
}

# ---- extend / status ------------------------------------------------------
do_extend() {
  [ -d "$RUN" ] || { log "recovery is not active"; exit 1; }
  arm_destruct
  log "recovery window extended by ${WINDOW_SECONDS}s"
}
do_status() {
  if [ -d "$RUN" ] && [ -f "$RUN/ports" ]; then
    echo "bastion-recovery: ACTIVE on port(s) $(cat "$RUN/ports")"
  else
    echo "bastion-recovery: inactive"
  fi
}

case "${1:-start}" in
  start)  do_start ;;
  stop)   do_stop ;;
  extend) do_extend ;;
  status) do_status ;;
  reap)   do_reap ;;
  reassert) do_reassert ;;
  *) echo "usage: bastion-recovery {start|stop|extend|status|reap|reassert}" >&2; exit 2 ;;
esac

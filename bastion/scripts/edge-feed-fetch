#!/usr/bin/env bash
# edge-feed-fetch — threat-feed SOURCE for edge-reconciler (ZERO firewall privilege).
# Pulls curated public blocklists, normalizes to one IPv4/IPv6 addr/CIDR per line, dedupes,
# and atomically writes the candidate list. It NEVER touches nft: every line it emits is
# validated by edge-reconciler (allowlist + per-family width floor) before it can enter
# blk_feed (v4) or blk_feed6 (v6) — so a loose v6 match here is safe, garbage is rejected there.
# Runs as an ephemeral unprivileged user (systemd DynamicUser), network only.
#
# Feed URLs come from FEED_SOURCES (space-separated, supplied via the unit's EnvironmentFile from
# machine.env — `bastion feeds add|remove|list`); the built-in defaults below are used when it is
# unset/blank, so a fresh install fetches sane lists with no config.
set -u
OUT="${STATE_DIRECTORY:-/var/lib/edge-feed}/blk_feed.list"
TMP="$(mktemp)"; trap 'rm -f "$TMP" "${OUT}.new"' EXIT   # never strand the staging file

# need <bin>... — B4 preflight: exit early with a clear message naming any missing required
# command, instead of failing obscurely mid-run. Reports to stderr + journal.
need(){ local b miss=''
  for b in "$@"; do command -v "$b" >/dev/null 2>&1 || miss="$miss $b"; done
  [ -z "$miss" ] && return 0
  printf 'bastion %s: missing required command(s):%s — install them and re-run\n' "${0##*/}" "$miss" >&2
  command -v logger >/dev/null 2>&1 && logger -t bastion "${0##*/}: missing required command(s):$miss"
  exit 1
}
# Without curl every feed fetch fails — surface the real cause, not "all feeds failed".
need curl

# Built-in defaults — used only when FEED_SOURCES is unset/blank (a fresh install with no operator
# overrides). `bastion feeds add|remove` writes FEED_SOURCES into machine.env to override these.
DEFAULT_FEEDS="\
https://raw.githubusercontent.com/firehol/blocklist-ipsets/master/firehol_level1.netset \
https://www.spamhaus.org/drop/drop.txt \
https://www.spamhaus.org/drop/dropv6.txt \
https://lists.blocklist.de/lists/all.txt"
read -r -a FEEDS <<< "${FEED_SOURCES:-$DEFAULT_FEEDS}"

ok=0
for url in "${FEEDS[@]}"; do
  if data="$(curl -fsS -m 30 --retry 2 "$url" 2>/dev/null)"; then
    clean="$(printf '%s\n' "$data" | sed -E 's/[#;].*$//')"
    # IPv4 addr/CIDR
    printf '%s\n' "$clean" | grep -oE '([0-9]{1,3}\.){3}[0-9]{1,3}(/[0-9]{1,2})?' >> "$TMP"
    # IPv6 addr/CIDR — permissive (needs >=2 colon groups); edge-reconciler is the real validator.
    printf '%s\n' "$clean" | grep -oiE '([0-9a-f]{0,4}:){2,7}[0-9a-f]{0,4}(/[0-9]{1,3})?' >> "$TMP"
    logger -t edge-feed-fetch "fetched OK: $url"
    ok=$((ok+1))
  else
    logger -t edge-feed-fetch "FETCH FAILED (skipped): $url"
  fi
done

if [ "$ok" -eq 0 ]; then
  logger -t edge-feed-fetch "all feeds failed -- keeping previous list, exit 1"; exit 1
fi
sort -u "$TMP" > "${OUT}.new"

# SUPPLY-CHAIN SANITY (F3, the IP-feed twin of edge-dnsblock-update's caps): refuse a sudden
# COLLAPSE (a truncated/poisoned/hijacked source silently shrinking the candidate list — which
# would unblock previously-blocked attackers) or an implausible EXPLOSION (memory exhaustion in
# the reconciler's parse/collapse). Either keeps the CURRENT list untouched + alerts. The
# reconciler's allowlist + width floor are the per-entry guard; this is the whole-list guard.
newcount=$(grep -c . "${OUT}.new")
oldcount=0; [ -f "$OUT" ] && oldcount=$(grep -c . "$OUT" 2>/dev/null)
MINRATIO=${FEED_MIN_RATIO:-40}; MAXENTRIES=${FEED_MAX:-2000000}
if [ "$oldcount" -ge 1000 ] && [ "$((newcount*100))" -lt "$((oldcount*MINRATIO))" ]; then
  rm -f "${OUT}.new"
  logger -t edge-feed-fetch "REFUSED: new=$newcount < ${MINRATIO}% of current=$oldcount (sources truncated/poisoned?) -- keeping current list, exit 1"; exit 1
fi
if [ "$newcount" -gt "$MAXENTRIES" ]; then
  rm -f "${OUT}.new"
  logger -t edge-feed-fetch "REFUSED: $newcount entries exceeds cap $MAXENTRIES (poisoned source?) -- keeping current list, exit 1"; exit 1
fi

mv -f "${OUT}.new" "$OUT"
logger -t edge-feed-fetch "wrote $newcount unique entries -> $OUT (from $ok/${#FEEDS[@]} feeds)"

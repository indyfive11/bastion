#!/usr/bin/env python3
# edge-ctl — operator control + human kill switch for the AI firewall layer.
# Fixed-purpose ROOT tool. Run it as root, or as a sudo-capable operator (it re-execs under sudo:
# interactively when it has a TTY, `sudo -n` when it does not, so it never hangs on a prompt in a
# UI/automation context). There is NO dedicated sudoers grant — it relies on your own sudo rights.
# It ONLY touches the ai_* sets / the edge-ai timer / the spool — never the base firewall.
#
#   edge-ctl status                 # timer state, ai_* set counts, last analysis, recent audit
#   edge-ctl panic                  # FLUSH all ai_* sets NOW + clear the spool (immediate undo)
#   edge-ctl ai-disable             # stop+disable edge-ai.timer, then panic (full stop)
#   edge-ctl ai-enable              # enable+start edge-ai.timer (arm)
#   edge-ctl rollback <id>          # remove the elements applied by one audit record id
#   edge-ctl proposals              # list PENDING propose_base_change suggestions (with ids)
#   edge-ctl accept <id>            # mark a proposal reviewed+accepted (you enact it manually)
#   edge-ctl reject <id>            # dismiss a proposal from the pending queue
#
import fcntl, hashlib, ipaddress, json, os, subprocess, sys, time

# The kill switch must reach BOTH families. The v4 sets are MANDATORY (always present once L0 is
# installed) — their flush failing is a real fault. The `…6` siblings are flushed too, but a node
# whose nft ruleset predates the IPv6 sets legitimately lacks them, so a missing v6 set is NOT a
# kill-switch failure (see flush_ai_sets / _flush_failures).
AI_SETS_V4 = ["ai_block", "ai_ratelimit", "ai_tarpit"]
AI_SETS6   = [s + "6" for s in AI_SETS_V4]
AI_SETS    = AI_SETS_V4 + AI_SETS6


def _nft_table():
    """The managed nft table: `inet edge` (edge) or `inet bastion` (endpoint). Read NFT_TABLE
    from the environment, else /etc/bastion/machine.env. Hardcoding `inet edge` would make the
    kill switch (panic/ai-disable/rollback) silently target a table that DOES NOT EXIST on an
    endpoint — leaving AI-imposed blocks in place. Falls back to inet edge for older configs."""
    val = os.environ.get("NFT_TABLE", "")
    if not val:
        try:
            with open("/etc/bastion/machine.env") as f:
                for line in f:
                    if line.strip().startswith("NFT_TABLE="):
                        val = line.split("=", 1)[1].strip().strip("'\"")
                        break
        except OSError:
            pass
    parts = val.split()
    return (parts[0], parts[1]) if len(parts) == 2 else ("inet", "edge")


FAM, TBL = _nft_table()
INTENTS  = "/var/lib/edge-ai/intents.json"
SIGNALS  = "/var/lib/edge-ai/signals.json"
PROPOSALS= "/var/lib/edge-ai/proposals.jsonl"
RESOLVED = "/var/lib/edge-ai/proposals-resolved.jsonl"   # accept/reject decisions (sidecar)
AUDIT    = "/var/log/edge-reconciler/audit.jsonl"
TIMER    = "edge-ai.timer"

# 0.4 — shared kill-switch lock. panic / ai-disable / rollback flush the ai_* sets and clear the
# spool; edge-reconciler takes LOCK_EX on the SAME file around a reconcile pass, so the reconciler
# can never re-add (from a half-read spool) the elements we just flushed. Same path + env override
# as edge-reconciler. Best-effort: if the lock can't be taken, the kill switch STILL runs (it must
# never be blocked by a lock problem) — it just loses the interleave guarantee for that invocation.
LOCK_FILE = os.environ.get("BASTION_RECONCILE_LOCK", "/run/edge-reconciler.lock")

class kill_switch_lock:
    def __enter__(self):
        self.fd = None
        try:
            self.fd = os.open(LOCK_FILE, os.O_CREAT | os.O_RDWR, 0o600)
            fcntl.flock(self.fd, fcntl.LOCK_EX)
        except OSError as e:
            print(f"warn: kill-switch lock unavailable ({e}) — proceeding unlocked", file=sys.stderr)
            if self.fd is not None:
                os.close(self.fd); self.fd = None
        return self
    def __exit__(self, *exc):
        if self.fd is not None:
            try:
                fcntl.flock(self.fd, fcntl.LOCK_UN)
            finally:
                os.close(self.fd)
        return False

def _norm_net(cidr):
    """Canonical `ip_network` form of an address/CIDR ("1.2.3.4" -> "1.2.3.4/32",
    "2001:db8::1" -> "2001:db8::1/128", "1.2.3.4/32" unchanged), or None if unparseable. Lets the
    rollback spool-prune compare audit elements and intent cidrs across families/forms (A7)."""
    try:
        return ipaddress.ip_network(str(cidr).strip(), strict=False).with_prefixlen
    except (ValueError, TypeError):
        return None


def ensure_root():
    if os.geteuid() == 0:
        return
    # Re-exec under sudo so `edge-ctl <cmd>` works for a sudo-capable operator. (C4) There is NO
    # /etc/sudoers.d/edge-ctl grant — the old `sudo -n` unconditionally failed for anyone without a
    # NOPASSWD rule, which is nobody. Prompt interactively when we have a TTY (the normal admin
    # model); use `-n` only without a TTY so a UI/automation caller fails fast instead of hanging.
    sudo = ["sudo"] if sys.stdin.isatty() else ["sudo", "-n"]
    try:
        os.execvp("sudo", sudo + ["/usr/local/sbin/edge-ctl"] + sys.argv[1:])
    except OSError:
        sys.stderr.write("edge-ctl must run as root (sudo unavailable)\n")
        sys.exit(1)

def nft(*args):
    return subprocess.run(["nft", *args], capture_output=True, text=True)

def audit(rec):
    rec["ts"] = time.strftime("%Y-%m-%dT%H:%M:%S%z")
    try:
        with open(AUDIT, "a") as f:
            f.write(json.dumps(rec, separators=(",", ":")) + "\n")
    except Exception as e:
        print(f"warn: audit write failed: {e}", file=sys.stderr)

def set_count(s):
    p = nft("-j", "list", "set", FAM, TBL, s)
    if p.returncode != 0:
        return None
    try:
        data = json.loads(p.stdout)
        for obj in data.get("nftables", []):
            st = obj.get("set")
            if st and st.get("name") == s:
                return len(st.get("elem", []) or [])
    except Exception:
        return None
    return 0

def flush_ai_sets():
    out = {}
    for s in AI_SETS:
        p = nft("flush", "set", FAM, TBL, s)
        if p.returncode == 0:
            out[s] = "flushed"
        elif _set_absent(p.stderr):
            # A v6 sibling can be legitimately absent on a node whose ruleset predates IPv6 sets;
            # nothing to flush there is not a kill-switch fault. A MISSING v4 set, however, still
            # trips _flush_failures (the managed table/sets shouldn't have vanished).
            out[s] = "absent"
        else:
            out[s] = f"ERR:{p.stderr.strip()[:80]}"
    return out


def _set_absent(stderr):
    e = (stderr or "").lower()
    return "does not exist" in e or "no such file" in e

def clear_spool():
    try:
        now = int(time.time())
        tmp = INTENTS + ".tmp"
        with open(tmp, "w") as f:
            json.dump({"version": 1, "generated_epoch": now, "backend": "edge-ctl:cleared",
                       "intents": []}, f)
        os.replace(tmp, INTENTS)
        return True
    except Exception as e:
        print(f"warn: could not clear spool: {e}", file=sys.stderr); return False

def systemctl(*args):
    return subprocess.run(["systemctl", *args], capture_output=True, text=True)

def cmd_status():
    print("== edge-ai timer ==")
    en = systemctl("is-enabled", TIMER).stdout.strip() or "?"
    ac = systemctl("is-active", TIMER).stdout.strip() or "?"
    print(f"  {TIMER}: enabled={en} active={ac}")
    print("== ai_* set element counts ==")
    for s in AI_SETS:
        print(f"  {s}: {set_count(s)}")
    print("== last analysis (intents.json) ==")
    try:
        with open(INTENTS) as f:
            doc = json.load(f)
        age = int(time.time()) - doc.get("generated_epoch", 0)
        print(f"  backend={doc.get('backend')} intents={len(doc.get('intents',[]))} age={age}s")
    except Exception as e:
        print(f"  (none: {e})")
    try:
        age = int(time.time()) - json.load(open(SIGNALS)).get("generated_epoch", 0)
        print(f"  signals age={age}s")
    except Exception:
        pass
    print("== recent ai audit rows ==")
    try:
        rows = [json.loads(l) for l in open(AUDIT)][-200:]
        ai = [r for r in rows if r.get("set") in AI_SETS][-6:]
        for r in ai:
            print(f"  id={r.get('id')} set={r.get('set')} applied={r.get('desired_count')} "
                  f"rejected={r.get('rejected_count')} ts={r.get('ts')}")
        if not ai:
            print("  (no ai audit rows yet)")
    except Exception as e:
        print(f"  (audit unavailable: {e})")
    return 0

def _flush_failures(res):
    """Sets whose flush returned a real nft error. A kill switch MUST NOT report success while it
    silently did nothing (e.g. the managed table/sets are gone, or NFT_TABLE resolved wrong), so
    these propagate to a non-zero exit. `nft flush set` succeeds on an existing-but-empty set, so
    a clean node never trips this. A v6 sibling reported "absent" (pre-IPv6 ruleset) is NOT a
    failure; a MANDATORY v4 set that is absent IS (it should always exist once L0 is installed)."""
    failed = []
    for s, r in res.items():
        if not isinstance(r, str):
            continue
        if r.startswith("ERR:"):
            failed.append(s)
        elif r == "absent" and s in AI_SETS_V4:
            failed.append(s)
    return failed

def cmd_panic():
    res = flush_ai_sets()
    spool_ok = clear_spool()
    failed = _flush_failures(res)
    audit({"event": "edge-ctl", "action": "panic", "flush": res, "ok": not failed})
    if failed or not spool_ok:
        print(f"PANIC INCOMPLETE: {len(res) - len(failed)}/{len(res)} ai_* sets flushed"
              + ("" if spool_ok else "; spool NOT cleared"))
    else:
        print("PANIC: flushed ai_* sets + cleared spool")
    for s, r in res.items():
        print(f"  {s}: {r}")
    return 1 if (failed or not spool_ok) else 0

def cmd_ai_disable():
    systemctl("disable", "--now", TIMER)
    res = flush_ai_sets(); spool_ok = clear_spool()
    failed = _flush_failures(res)
    audit({"event": "edge-ctl", "action": "ai-disable", "flush": res, "ok": not failed})
    if failed or not spool_ok:
        print(f"AI DISABLED ({TIMER} stopped) but FLUSH INCOMPLETE: "
              f"{len(res) - len(failed)}/{len(res)} ai_* sets flushed"
              + ("" if spool_ok else "; spool NOT cleared"))
        for s, r in res.items():
            print(f"  {s}: {r}")
        return 1
    print(f"AI DISABLED: {TIMER} stopped+disabled; ai_* flushed; spool cleared")
    return 0

def cmd_ai_enable():
    # daemon-reload first so a regenerated edge-ai.timer (changed ai.timer_interval) is picked up,
    # then enable + restart so the CURRENT on-disk cadence is what arms — re-running `ai enable`
    # after editing the interval is enough to apply it (no stale running timer on the old value).
    systemctl("daemon-reload")
    systemctl("enable", TIMER)
    p = systemctl("restart", TIMER)
    audit({"event": "edge-ctl", "action": "ai-enable", "rc": p.returncode})
    if p.returncode == 0:
        print(f"AI ENABLED: {TIMER} enabled+started")
    else:
        print(f"enable failed: {p.stderr.strip()}")
    return p.returncode

def cmd_rollback(rid):
    try:
        rows = [json.loads(l) for l in open(AUDIT)]
    except Exception as e:
        print(f"cannot read audit: {e}"); return 1
    rec = next((r for r in rows if str(r.get("id")) == str(rid) and r.get("set") in AI_SETS), None)
    if not rec:
        print(f"no ai audit record with id={rid}"); return 1
    s = rec["set"]; elems = rec.get("ai_elements", [])
    if not elems:
        print(f"record {rid} has no ai_elements to remove"); return 1
    # remove from live set
    removed = []
    for c in elems:
        p = nft("delete", "element", FAM, TBL, s, "{ " + c + " }")
        removed.append((c, "ok" if p.returncode == 0 else p.stderr.strip()[:60]))
    # remove from spool so the reconciler won't re-add. Match by NORMALIZED network on BOTH sides
    # (A7): the audit element and the intent cidr canonicalize to the same `ip_network` form, so a
    # bare host, an explicit /32, AND an IPv6 /128 all compare equal. The old code special-cased
    # only "/32" (string suffix), so an IPv6 block like "2001:db8::1/128" never matched the bare
    # intent "2001:db8::1" and the reconciler RE-ADDED the rolled-back block on the next tick.
    try:
        elem_norms = {n for n in (_norm_net(c) for c in elems) if n}
        doc = json.load(open(INTENTS))
        before = len(doc.get("intents", []))
        doc["intents"] = [i for i in doc.get("intents", [])
                          if _norm_net(i.get("cidr")) not in elem_norms
                          and str(i.get("cidr")) not in elems]
        tmp = INTENTS + ".tmp"
        json.dump(doc, open(tmp, "w")); os.replace(tmp, INTENTS)
        pruned = before - len(doc["intents"])
    except Exception as e:
        pruned = f"spool-prune-failed:{e}"
    audit({"event": "edge-ctl", "action": "rollback", "id": rid, "set": s,
           "removed": removed, "spool_pruned": pruned})
    print(f"ROLLBACK id={rid} set={s}: removed {len(removed)} elements; spool pruned={pruned}")
    for c, st in removed:
        print(f"  {c}: {st}")
    return 0

_CTRL_TBL = {c: None for c in range(0x20)}; _CTRL_TBL[0x7f] = None
def _safe(s, n=160):
    """Strip control chars (ANSI/escape injection, D6) before printing model-origin text to the
    terminal. edge-ai-analyze already cleans at the source; this guards an older/hand-edited file."""
    return str(s).translate(_CTRL_TBL)[:n]


def _proposal_id(rec):
    """Stable content-derived id (proposals.jsonl carries no id of its own). Survives the
    append-only file being logrotated; duplicate-content proposals collapse to one id (harmless)."""
    raw = f"{rec.get('ts','')}\x00{rec.get('description','')}".encode()
    return hashlib.sha1(raw).hexdigest()[:12]


def _load_proposals():
    try:
        return [json.loads(l) for l in open(PROPOSALS) if l.strip()]
    except FileNotFoundError:
        return []


def _resolved_ids():
    ids = set()
    try:
        for l in open(RESOLVED):
            if l.strip():
                ids.add(json.loads(l).get("id"))
    except FileNotFoundError:
        pass
    return ids


def _pending_proposals():
    """(id, record) for proposals not yet accepted/rejected; dedup by id."""
    resolved = _resolved_ids()
    seen, out = set(), []
    for r in _load_proposals():
        pid = _proposal_id(r)
        if pid in resolved or pid in seen:
            continue
        seen.add(pid); out.append((pid, r))
    return out


def cmd_proposals():
    pend = _pending_proposals()
    if not pend:
        print("(no pending proposals)"); return 0
    print(f"== pending AI proposals ({len(pend)}) — review, then `edge-ctl accept|reject <id>` ==")
    for pid, r in pend[-50:]:
        print(f"  {pid}  [{r.get('ts','?')}]  {_safe(r.get('description',''))}")
    print("NOTE: advisory base/access suggestions — NOTHING is auto-applied. 'accept' only records")
    print("your decision; enact the change yourself (e.g. edit machine.conf + `bastion generate`).")
    return 0


def cmd_proposal_resolve(pid, disposition):
    match = next((r for i, r in _pending_proposals() if i == pid), None)
    if match is None:
        print(f"no pending proposal with id {pid} (see `edge-ctl proposals`)"); return 1
    rec = {"id": pid, "disposition": disposition,
           "ts": time.strftime("%Y-%m-%dT%H:%M:%S%z"),
           "description": match.get("description", "")[:160]}
    try:
        with open(RESOLVED, "a") as f:
            f.write(json.dumps(rec, separators=(",", ":")) + "\n")
    except Exception as e:
        print(f"error: could not record decision: {e}", file=sys.stderr); return 1
    audit({"event": "edge-ctl", "action": f"proposal-{disposition}", "id": pid})
    print(f"proposal {pid} {disposition}.")
    if disposition == "accept":
        print("  reminder: enact the change manually — bastion never auto-applies base/access changes.")
    return 0

def _locked(fn, *args):
    with kill_switch_lock():
        return fn(*args)

def main():
    ensure_root()
    args = sys.argv[1:]
    if not args:
        print(__doc__); return 0
    c = args[0]
    if c == "status":    return cmd_status()
    # The set-mutating verbs run under the shared lock so a concurrent reconcile pass can't
    # re-add what they flush (0.4). ai-enable only arms the timer (no set writes) — no lock.
    if c == "panic":     return _locked(cmd_panic)
    if c == "ai-disable":return _locked(cmd_ai_disable)
    if c == "ai-enable": return cmd_ai_enable()
    if c == "rollback":
        if len(args) < 2: print("usage: edge-ctl rollback <id>"); return 1
        return _locked(cmd_rollback, args[1])
    if c == "proposals": return cmd_proposals()
    if c in ("accept", "reject"):
        if len(args) < 2: print(f"usage: edge-ctl {c} <id>"); return 1
        return cmd_proposal_resolve(args[1], c)
    print(f"unknown command: {c}\n{__doc__}"); return 1

if __name__ == "__main__":
    sys.exit(main())

#!/usr/bin/env bash
# net-confirm — confirm egress is genuinely up and STABLE (~45s), then disarm the watchdog
# (accept the current config as the new baseline). If any check fails it does NOT disarm and
# exits non-zero, leaving the watchdog armed (fail-safe: uncertainty keeps the rollback net).
# This is the operator-side "confirm" half of the apply-then-canary pattern.
[ -r /etc/bastion/machine.env ] && . /etc/bastion/machine.env
EGRESS_PROBE=${EGRESS_PROBE:-https://api.anthropic.com}
PROBE_HOST=${EGRESS_PROBE#*://}; PROBE_HOST=${PROBE_HOST%%/*}

log(){ logger -t bastion "net-confirm: $*"; }
check(){ getent hosts "$PROBE_HOST" >/dev/null 2>&1 && \
         curl -s -o /dev/null --max-time 6 "$EGRESS_PROBE"; }
log "verifying stable egress before disarm..."
for i in 1 2 3 4; do
  if check; then log "egress check $i/4 OK"
  else log "egress check $i/4 FAILED — NOT disarming; watchdog stays armed"; exit 1; fi
  [ "$i" -lt 4 ] && sleep 15
done
systemctl stop edge-watchdog.service 2>/dev/null || true
log "egress stable; watchdog DISARMED. Current config retained as the new baseline."
exit 0

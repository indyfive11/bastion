#!/usr/bin/env bash
# net-confirm — confirm egress is genuinely up and STABLE (~45s). Exit 0 means stable, so the
# caller (`bastion confirm`) may disarm a pending cutover deadman and accept the current config as
# the new baseline; any failed check exits non-zero so the caller leaves the rollback net armed
# (fail-safe: uncertainty keeps the net). This is the operator-side "confirm" half of the
# apply-then-canary pattern.
#
# F15: this does NOT stop edge-watchdog. That unit is the STANDING L6 self-heal (Restart=always,
# "standing egress/relay self-heal") and must keep running after a confirm — stopping it here left
# the box with no ongoing self-heal until reboot. The cutover deadman is a SEPARATE transient unit
# (bastion-switch-deadman) that the caller disarms; this script only reports egress stability.
[ -r /etc/bastion/machine.env ] && . /etc/bastion/machine.env
EGRESS_PROBE=${EGRESS_PROBE:-https://api.anthropic.com}
PROBE_HOST=${EGRESS_PROBE#*://}; PROBE_HOST=${PROBE_HOST%%/*}

log(){ logger -t bastion "net-confirm: $*"; }
# need <bin>... — B4 preflight: exit early with a clear message naming any missing required
# command, instead of failing obscurely mid-run. Reports to stderr + journal.
need(){ local b miss=''
  for b in "$@"; do command -v "$b" >/dev/null 2>&1 || miss="$miss $b"; done
  [ -z "$miss" ] && return 0
  printf 'bastion %s: missing required command(s):%s — install them and re-run\n' "${0##*/}" "$miss" >&2
  command -v logger >/dev/null 2>&1 && logger -t bastion "${0##*/}: missing required command(s):$miss"
  exit 1
}
# Without curl every egress check FAILS and the watchdog would never disarm — say why, plainly.
need curl
check(){ getent hosts "$PROBE_HOST" >/dev/null 2>&1 && \
         curl -s -o /dev/null --max-time 6 "$EGRESS_PROBE"; }
log "verifying stable egress..."
for i in 1 2 3 4; do
  if check; then log "egress check $i/4 OK"
  else log "egress check $i/4 FAILED — NOT disarming; watchdog stays armed"; exit 1; fi
  [ "$i" -lt 4 ] && sleep 15
done
log "egress stable; confirm OK. Current config retained as the new baseline."
exit 0

#!/usr/bin/env bash
# notify-failure — invoked by systemd via OnFailure=notify-failure@%n.service
# $1 is the failed unit name (the template instance, %i).
# Gathers a short status snapshot and hands it to notify-alert (journal + ntfy + email).
set -u

unit="${1:-unknown.unit}"
host="$(hostname 2>/dev/null || cat /etc/hostname 2>/dev/null || echo unknown)"
status="$(systemctl status --no-pager --full "$unit" 2>&1 | tail -n 20)"

exec /usr/local/sbin/notify-alert "Service FAILED: ${unit} on ${host}" "${status}"

#!/usr/bin/env bash
# edge-watchdog — standing egress/relay self-heal for a bastion edge node.
# Permanent successor to net-monitor (which is a SHORT-window cutover tool):
#   * persistent loop, re-arms after acting (net-monitor is single-shot)
#   * self-refreshing known-good snapshot while stable (kills the stale-snapshot
#     footgun that caused the 2026-06-05 edge<->UFW flap)
#   * us-vs-ISP discrimination: upstream/ISP outages => ALERT ONLY, never roll back
#     (a rollback can't fix an upstream outage; avoid churn)
#   * desired-state aware: a DOWN relay/tunnel interface is upstream, NOT "our config
#     broken" — never heals/rolls back to repair it (a heal can't revive a dead far-end)
#   * graduated heal, but flush-averse + cooldown-gated: reload the static ruleset ONLY
#     when the table is actually GONE (never flush live NAT/conntrack on a hot poll); when
#     the table is present, just refill the reconciler-managed sets. HEAL_COOLDOWN floor
#     between heals so a heal that can't fix the cause can't thrash (the failover-lockout
#     class: forced-tunnel far-end dies -> dead-relay "heal" loop IS the outage).
#   * closes the LAN-client blind spot via conntrack (node self-egress can be green
#     while LAN clients are cut)
#   * firewall-aware: reuses /var/lib/net-safe snapshot + net-{snapshot,rollback}
#   * alerts: FULL detail to the local journal ONLY; any external/ntfy push is a
#     GENERIC "see runbook" line — never arch detail on unencrypted channels (HARD RULE).
# Runs as ROOT via edge-watchdog.service (Restart=always). nft/iptables/ip/ping/
# conntrack all work unprivileged-of-sudo here because the service is root.
#
# Modes:  edge-watchdog          -> daemon loop
#         edge-watchdog once     -> single evaluation (testing)
# Env:    POLL, EGRESS_FAIL_TRIPS, REFRESH_AFTER, WAN_DOWN_BACKOFF, HEAL_COOLDOWN, DRYRUN=1 (log, don't act)
# Test hooks (in $RUN): simulate-egress-dead, simulate-isp-down,
#         simulate-config-broken, simulate-lan-broken, simulate-wan-carrier-down
# Pause:  touch /run/edge-watchdog/pause   (or /etc/edge-watchdog/disabled)
set -u

RUN=/run/edge-watchdog
CONF=/etc/edge-watchdog
SNAP=/var/lib/net-safe/snapshot
NFT_CONF=${NFT_CONF:-/etc/nftables.conf}          # static ruleset reloaded by heal_light (test seam)
RECOVERY_RUN=${RECOVERY_RUN:-/run/bastion-recovery} # bastion-recovery's runtime dir (test seam)
mkdir -p "$RUN"

POLL=${POLL:-30}
EGRESS_FAIL_TRIPS=${EGRESS_FAIL_TRIPS:-3}     # consecutive fails before acting (~90s @30s)
REFRESH_AFTER=${REFRESH_AFTER:-1800}          # re-snapshot known-good after this many stable sec
WAN_DOWN_BACKOFF=${WAN_DOWN_BACKOFF:-300}     # while WAN carrier is physically down: re-log at most this often
HEAL_COOLDOWN=${HEAL_COOLDOWN:-900}           # anti-thrash floor: minimum seconds between firewall heals
DRYRUN=${DRYRUN:-0}

# Machine-specific values are sourced from the bastion-generated env file
# (`bastion generate` writes /etc/bastion/machine.env from machine.conf). Fallbacks
# below are generic placeholders so the script never carries a real topology value.
[ -r /etc/bastion/machine.env ] && . /etc/bastion/machine.env
WAN_IF=${WAN_IF:-}                             # WAN/uplink interface (edge mode; physical-carrier probe)
GATEWAY=${GATEWAY:-}                           # LAN default gateway IP
RELAY_IF=${RELAY_IF:-}                         # upstream relay/tunnel interface (optional)
LAN_NET=${LAN_NET:-}                           # LAN CIDR
LAN_IP=${LAN_IP:-}                             # this node's LAN IP (DNS-leak local-chain classifier)
DNS_UPSTREAM=${DNS_UPSTREAM:-}                 # local stub resolver host#port (DNS-leak-watch gate)
RELAY_DST=${RELAY_DST:-}                       # relay far-end probe target (optional)
EXT_PINGS=${EXT_PINGS:-"1.1.1.1 8.8.8.8 9.9.9.9"}   # diverse external endpoints (ISP-up signal)
EXT_HTTPS=${EXT_HTTPS:-"https://api.anthropic.com https://www.cloudflare.com"}
MODE=${MODE:-edge}                            # edge | endpoint — endpoint never rolls back (no edge config to repair)

# need <bin>... — B4 preflight: exit early with a clear message naming any missing required
# command, instead of failing obscurely mid-run. Reports to stderr + journal.
need(){ local b miss=''
  for b in "$@"; do command -v "$b" >/dev/null 2>&1 || miss="$miss $b"; done
  [ -z "$miss" ] && return 0
  printf 'bastion %s: missing required command(s):%s — install them and re-run\n' "${0##*/}" "$miss" >&2
  command -v logger >/dev/null 2>&1 && logger -t bastion "${0##*/}: missing required command(s):$miss"
  exit 1
}
# The self-heal loop is inert without these: nft (firewall reload), ip (carrier/route), curl
# (egress probe), ping (gateway/external reachability). Fail fast so the journal names the gap.
need nft ip curl ping

log(){ logger -t edge-watchdog "$*"; }
# alert(): FULL detail to local journal; external push (only if configured) is GENERIC.
alert(){
  log "ALERT: $*"
  local urlf="$CONF/internal-ntfy-url"
  [ -f "$urlf" ] && curl -fsS -m 5 -d "edge-watchdog: state change — see runbook" "$(cat "$urlf")" >/dev/null 2>&1 || true
}

paused(){ [ -f "$RUN/pause" ] || [ -f "$CONF/disabled" ]; }

# ---------- health probes ----------
egress_ok(){
  [ -f "$RUN/simulate-egress-dead" ] && return 1
  local u
  for u in $EXT_HTTPS; do curl -s -o /dev/null -m 6 "$u" && return 0; done
  return 1
}
gateway_ok(){ ping -c1 -W1 "$GATEWAY" >/dev/null 2>&1; }
ext_reachable(){                                  # any diverse external answers ICMP (independent of relay)
  [ -f "$RUN/simulate-isp-down" ] && return 1
  local ip
  for ip in $EXT_PINGS; do ping -c1 -W1 "$ip" >/dev/null 2>&1 && return 0; done
  return 1
}
# wan_carrier_down: is the physical WAN uplink carrier down? (cable unplugged, ONT/modem
# reboot, ISP maintenance, upstream power-down). When the carrier drops, the OS removes the
# default route — which config_ok() would otherwise misread as "OUR config broken" and try to
# roll back, churning useless rollbacks + false "MANUAL intervention" alerts that drown out the
# real outage. A rollback can't restore a route over a dead carrier, so this gates that branch.
# Empty WAN_IF (endpoint mode / unset) => not applicable, treat as up.
wan_carrier_down(){
  [ -f "$RUN/simulate-wan-carrier-down" ] && return 0
  [ -n "$WAN_IF" ] || return 1
  ip -o link show "$WAN_IF" 2>/dev/null | grep -q LOWER_UP && return 1
  return 0
}
# config_ok: is OUR edge config intact? firewall-agnostic (edge OR ufw, whichever governs).
# echoes a reason on failure; returns 0 if intact.
config_ok(){
  [ -f "$RUN/simulate-config-broken" ] && { echo "simulated-broken"; return 1; }
  local fw
  if nft list table inet edge >/dev/null 2>&1; then fw=edge
  elif systemctl is-active --quiet ufw; then fw=ufw
  else echo "no-firewall"; return 1; fi
  if [ "$fw" = edge ]; then
    nft list table ip edge_nat 2>/dev/null | grep -qE "${RELAY_IF}.*masquerade" || { echo "relay-masq-missing(edge)"; return 1; }
  else
    iptables -t nat -C POSTROUTING -s "$LAN_NET" -o "$RELAY_IF" -j MASQUERADE 2>/dev/null || { echo "relay-masq-missing(ufw)"; return 1; }
  fi
  # A DOWN relay/tunnel interface is NOT "our config broken": a wg tunnel is connectionless, so the
  # iface vanishing means the far-end (the VPS) is gone — an upstream/desired-state condition a local
  # heal or rollback can NEVER repair (it would only thrash, re-asserting a dead-tunnel dependency —
  # the failover-lockout class). Relay forward health is judged by evidence instead (lan_relay_broken);
  # a dead relay with a working direct-WAN fallback is normal. So config_ok no longer fails here.
  ip route show default | grep -q .                  || { echo "default-route-missing"; return 1; }
  return 0
}
# lan_relay_broken: true ONLY if LAN clients are actively using the relay but getting
# zero replies (relay forward broken). No traffic / no evidence = not broken.
# Reads the conntrack table from /proc/net/nf_conntrack when readable, else `conntrack -L`
# over netlink — modern kernels build CONFIG_NF_CONNTRACK_PROCFS off, so the procfs file is
# absent and only conntrack-tools (shipped in L6) can read the table. No source at all =>
# can't observe => not-broken (the no-evidence default), warned once. CT_PROC overridable for tests.
lan_relay_broken(){
  [ -f "$RUN/simulate-lan-broken" ] && return 0
  [ -n "$RELAY_DST" ] || return 1
  local ct_proc="${CT_PROC:-/proc/net/nf_conntrack}" ct total replied
  if [ -r "$ct_proc" ]; then
    ct=$(cat "$ct_proc" 2>/dev/null)
  elif command -v conntrack >/dev/null 2>&1; then
    ct=$(conntrack -L 2>/dev/null)
  else
    [ -f "$RUN/conntrack-missing-warned" ] || {
      log "lan_relay_broken: no conntrack source ($ct_proc absent + conntrack binary missing) — LAN-client relay check disabled; install conntrack-tools"
      : > "$RUN/conntrack-missing-warned"
    }
    return 1
  fi
  total=$(grep -c "dst=${RELAY_DST}" <<<"$ct")
  [ "${total:-0}" -eq 0 ] && return 1
  replied=$(grep "dst=${RELAY_DST}" <<<"$ct" | grep -vc UNREPLIED)
  [ "${replied:-0}" -eq 0 ] && return 0
  return 1
}
# resolv_leak / resolved_upstreams_leak: mirror flowcheck's host-resolver leak guard so a leak that
# appears AFTER setup (e.g. a later DHCP renew re-points /etc/resolv.conf at the ISP's resolver, or
# systemd-resolved starts forwarding to it) is noticed in steady state — flowcheck only fires at
# check-time. "Local" = loopback (incl. resolved's 127.0.0.53) or this node's LAN_IP; anything else
# is a leak past the hardened dnsmasq->unbound->VPS chain. Echoes the leaking server(s), rc 0 = leak.
# Both honor the same RESOLV_CONF / RESOLVECTL test overrides as flowcheck.
resolved_upstreams_leak(){
  local rc="${RESOLVECTL:-resolvectl}" srv leak=""
  command -v "$rc" >/dev/null 2>&1 || return 1
  for srv in $("$rc" dns 2>/dev/null | sed 's/^[^:]*://' | tr ' ' '\n' | sed 's/#.*$//' | grep -E '^[0-9a-fA-F:.]+$'); do
    case "$srv" in
      127.*|::1|::|"$LAN_IP"|"") ;;
      *) leak="$leak $srv" ;;
    esac
  done
  [ -n "$leak" ] && { echo "$leak"; return 0; }
  return 1
}
resolv_leak(){
  local f="${RESOLV_CONF:-/etc/resolv.conf}" ns leak="" stub_resolved=""
  [ -r "$f" ] || return 1
  for ns in $(awk '/^[[:space:]]*nameserver/{print $2}' "$f"); do
    case "$ns" in
      127.0.0.53)          stub_resolved=1 ;;
      127.*|::1|"$LAN_IP") ;;
      *) leak="$leak $ns" ;;
    esac
  done
  [ -z "$leak" ] && [ -n "$stub_resolved" ] && { leak=$(resolved_upstreams_leak) || leak=""; }
  [ -n "$leak" ] && { echo "$leak"; return 0; }
  return 1
}
# dns_leak_watch: active surfacing of the host-resolver leak in steady state. Edge-only, and only
# when a loopback stub chain is expected (DNS_UPSTREAM is loopback) — an endpoint or an external
# upstream legitimately points elsewhere. Alert-once + latch (clear on recovery), exactly like the
# WAN-carrier guard, so it gets the GENERIC no-arch-leak ntfy push for free. ALERT ONLY: bastion
# never rewrites resolv.conf — that's the OS/operator's network config (narrowest scope).
dns_leak_watch(){
  [ "$MODE" = endpoint ] && return 0
  case "${DNS_UPSTREAM%%#*}" in 127.*|::1) ;; *) return 0 ;; esac
  local leak
  if leak=$(resolv_leak); then
    [ -f "$RUN/dns-leak-alerted" ] || {
      alert "host resolver leak — /etc/resolv.conf bypasses the local DNS chain (points at$leak) — check DHCP/resolv.conf"
      : > "$RUN/dns-leak-alerted"
    }
  elif [ -f "$RUN/dns-leak-alerted" ]; then
    rm -f "$RUN/dns-leak-alerted"
    alert "host resolver leak cleared — resolv.conf back on the local DNS chain"
  fi
}

# ---------- heal cooldown (anti-thrash) ----------
# A heal that can't fix the cause (a dead upstream tunnel) must NOT re-fire every poll — that
# tight loop, each reloading/rolling-back shared state, IS the failover-lockout outage. heal_allowed
# enforces a hard floor; evaluate() alerts-and-observes instead of re-healing inside the window.
# Stamped per incident (mark_healed) so a light->full escalation within one incident still runs.
heal_allowed(){
  local now last
  now=$(date +%s); last=$(cat "$RUN/last-heal" 2>/dev/null || echo 0)
  [ $((now - last)) -ge "$HEAL_COOLDOWN" ]
}
mark_healed(){ date +%s > "$RUN/last-heal"; }

# ---------- heals (graduated) ----------
heal_light(){   # cheapest heal: refill managed sets if the table is LIVE; recreate it only if GONE
  # INVARIANT — no flush in a hot path: if bastion's table is PRESENT, never reload $NFT_CONF. Its
  # preamble (`flush ruleset` in exclusive scope) would drop ALL live NAT + conntrack for the reload
  # window, and on a fast poll that drop IS the outage. A present table just needs its reconciler-
  # managed sets (cs_block/blk_feed/ai_*) refilled — that is the reconciler's job (Commandment #7),
  # not a ruleset reload. Only when the table is actually GONE do we recreate it from the static file
  # (the preamble flush is then moot — nothing live to drop).
  if nft list table inet edge >/dev/null 2>&1; then
    systemctl start edge-reconciler.service >/dev/null 2>&1 \
      || /usr/local/sbin/edge-reconciler >/dev/null 2>&1 || true
    log "heal: edge table present — refilled managed sets via reconciler (no ruleset reload, no flush)"
    return
  fi
  if [ -f "$SNAP/fw-nftables-active" ]; then
    # The table is MISSING — recreate it from the static config. Fold the live `inet bastion_recovery`
    # table (if a recovery window is open) into the SAME atomic transaction so the reload can't strand
    # emergency SSH, then kick the reconciler to refill the managed sets rather than waiting for the timer.
    local script rec
    script=$(cat "$NFT_CONF" 2>/dev/null) || { log "heal: cannot read $NFT_CONF — reload skipped"; return; }
    if [ -e "$RECOVERY_RUN" ] && rec=$(nft -s list table inet bastion_recovery 2>/dev/null) && [ -n "$rec" ]; then
      script="$script"$'\n'"$rec"
    fi
    if printf '%s\n' "$script" | nft -f - 2>/dev/null; then
      log "heal: edge table was MISSING — recreated from static config (recovery preserved; refilling sets)"
      systemctl start edge-reconciler.service >/dev/null 2>&1 \
        || /usr/local/sbin/edge-reconciler >/dev/null 2>&1 || true
      # The fresh main table dropped recovery's main-table reachability accept; if a recovery window
      # is open, re-punch it (the override table was folded back above).
      [ -e "$RECOVERY_RUN" ] && /usr/local/sbin/bastion-recovery reassert >/dev/null 2>&1 || true
    else
      log "heal: nft reload FAILED"
    fi
  else
    /usr/local/sbin/net-rollback edge-watchdog-light >/dev/null 2>&1 && log "heal: net-rollback (ufw relay ensure)"
  fi
}
heal_full(){ /usr/local/sbin/net-rollback edge-watchdog >/dev/null 2>&1 && log "heal: full net-rollback executed"; }

# ---------- known-good refresh ----------
maybe_refresh(){
  local now last
  now=$(date +%s)
  last=$(cat "$RUN/last-good-snapshot" 2>/dev/null || echo 0)
  if config_ok >/dev/null && ! lan_relay_broken && [ $((now - last)) -ge "$REFRESH_AFTER" ]; then
    if [ "$DRYRUN" = 1 ]; then log "[DRYRUN] would refresh known-good snapshot (stable ${REFRESH_AFTER}s)"; return; fi
    systemctl start net-snapshot.service 2>/dev/null && { echo "$now" > "$RUN/last-good-snapshot"; log "known-good snapshot refreshed (stable ${REFRESH_AFTER}s)"; }
  fi
}

# ---------- one evaluation cycle ----------
evaluate(){
  if paused; then log "paused — no action"; return; fi

  if egress_ok; then
    fails=0
    if [ -f "$RUN/wan-down-alerted" ]; then
      rm -f "$RUN/wan-down-alerted"
      alert "WAN carrier/egress recovered (${WAN_IF:-wan} back up) — resuming normal watch"
    fi
    if lan_relay_broken; then
      if ! heal_allowed; then
        alert "LAN-client relay degraded but within ${HEAL_COOLDOWN}s heal cooldown — observing, not re-churning (a heal can't revive a dead far-end)"
        return
      fi
      alert "egress OK but LAN-client relay degraded (clients sending, zero replies) — light heal"
      [ "$DRYRUN" = 1 ] && { log "[DRYRUN] would heal_light (relay forward)"; return; }
      heal_light; sleep 3
      lan_relay_broken && alert "LAN relay STILL degraded after light heal — escalating to full rollback" && heal_full
      mark_healed
      return
    fi
    dns_leak_watch
    maybe_refresh
    return
  fi

  # egress is failing
  fails=$((fails+1))
  log "egress check failed (${fails}/${EGRESS_FAIL_TRIPS})"
  [ "$fails" -lt "$EGRESS_FAIL_TRIPS" ] && return

  # Endpoint mode: this node doesn't route, has no relay, and its firewall is `inet bastion` (NOT
  # the `inet edge` table config_ok repairs); net-rollback is an edge-recovery tool. A sustained
  # egress loss here is almost always the host's own uplink (wifi/cable) — alert only, NEVER roll
  # back an endpoint (rolling back edge network state could disrupt an ordinary workstation).
  if [ "$MODE" = endpoint ]; then
    alert "sustained egress loss on endpoint node — ALERT ONLY (no rollback; check this host's uplink)"
    fails=0; return
  fi

  # sustained egress failure — physical uplink FIRST: a rollback can't restore a route over a
  # dead carrier, and treating the OS-removed default route as "our config broken" here is the
  # nightly-blackout rollback-churn / false-MANUAL-alert bug. Carrier down => ALERT ONCE, back off.
  if wan_carrier_down; then
    local now2 since
    now2=$(date +%s); since=$(cat "$RUN/wan-down-alerted" 2>/dev/null || echo 0)
    if [ "${since:-0}" -eq 0 ]; then
      alert "sustained egress loss + WAN carrier DOWN (${WAN_IF:-wan}) => physical/upstream uplink outage — ALERT ONCE, no rollback"
      echo "$now2" > "$RUN/wan-down-alerted"
    elif [ $((now2 - since)) -ge "$WAN_DOWN_BACKOFF" ]; then
      log "WAN carrier still down (${WAN_IF:-wan}) — backing off ${WAN_DOWN_BACKOFF}s, no rollback"
      echo "$now2" > "$RUN/wan-down-alerted"
    fi
    fails=0; return
  fi

  # carrier is up — diagnose us-vs-upstream
  local cfg rc
  cfg=$(config_ok); rc=$?
  if [ "$rc" -ne 0 ]; then
    if ! heal_allowed; then
      alert "sustained egress loss + OUR config broken (${cfg}) but within ${HEAL_COOLDOWN}s heal cooldown — observing, NOT re-healing (anti-thrash: a heal that didn't fix it must not loop)"
      fails=0; return
    fi
    alert "sustained egress loss + OUR config broken (${cfg}) — self-healing"
    if [ "$DRYRUN" = 1 ]; then log "[DRYRUN] would heal_light, verify egress, then heal_full if still down"; fails=0; return; fi
    heal_light; sleep 5
    if egress_ok; then alert "recovered after light heal"; mark_healed; fails=0; return; fi
    heal_full; sleep 5
    mark_healed
    if egress_ok; then alert "recovered after full rollback"; else alert "STILL DOWN after full rollback — MANUAL intervention needed"; fi
    fails=0; return
  fi

  # our config is intact — is this upstream?
  if gateway_ok && ! ext_reachable; then
    alert "sustained egress loss; local gateway UP + config intact + all external down => UPSTREAM/ISP outage — ALERT ONLY, no rollback"
    fails=0; return
  fi
  if ! gateway_ok; then
    if ! heal_allowed; then
      alert "sustained egress loss + gateway UNREACHABLE but within ${HEAL_COOLDOWN}s heal cooldown — observing, no rollback (anti-thrash)"
      fails=0; return
    fi
    alert "sustained egress loss + gateway UNREACHABLE + config intact — full rollback (local recovery: addr/route/fw)"
    if [ "$DRYRUN" = 1 ]; then log "[DRYRUN] would heal_full (local recovery)"; fails=0; return; fi
    heal_full; sleep 5; mark_healed; egress_ok && alert "recovered after rollback"
    fails=0; return
  fi
  # gateway up, some external reachable via ICMP, but our HTTPS egress down: relay far-end / VPS / DNS.
  alert "sustained egress loss; config intact, gateway+external reachable => relay far-end/VPS/DNS suspected — ALERT ONLY, observing"
  fails=0
}

# ---------- main ----------
fails=0
echo "$(date +%s)" > "$RUN/last-good-snapshot"   # seed so first auto-refresh is REFRESH_AFTER out
if [ "${1:-}" = "once" ]; then evaluate; exit 0; fi
log "started (poll=${POLL}s trips=${EGRESS_FAIL_TRIPS} refresh=${REFRESH_AFTER}s dryrun=${DRYRUN})"
while true; do
  sleep "$POLL"
  evaluate
done
